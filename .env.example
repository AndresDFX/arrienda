# ============================================================================
# ARRIENDA+ — Variables de entorno (plantilla)
# Copia este archivo a `.env` y completa los valores.
# NUNCA subas `.env` al repositorio (ya esta en .gitignore).
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase
# Local: tras `supabase start`, usa los valores que imprime la CLI.
# Cloud: toma estos valores de Project Settings > API en supabase.com.
# ----------------------------------------------------------------------------
# Expuestas al cliente (prefijo VITE_ para que Vite las incluya en el bundle):
VITE_SUPABASE_URL="http://127.0.0.1:54321"
VITE_SUPABASE_ANON_KEY="eyJhbGciOi...anon-key-local..."

# Solo servidor (NUNCA exponer al cliente). Usada por server functions y scraper.
SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...service-role-key-local..."

# ----------------------------------------------------------------------------
# Pasarela de pagos
# En Fase 0 usamos el adaptador "mock" (no requiere credenciales).
# Cambia a "wompi" cuando tengas llaves de prueba/produccion.
# ----------------------------------------------------------------------------
PAYMENTS_PROVIDER="mock"
COMMISSION_RATE="0.05"

# Wompi (solo cuando PAYMENTS_PROVIDER=wompi)
WOMPI_PUBLIC_KEY=""
WOMPI_PRIVATE_KEY=""
WOMPI_EVENTS_SECRET=""
WOMPI_BASE_URL="https://sandbox.wompi.co/v1"

# ----------------------------------------------------------------------------
# Scraper (apps/scraper) — Fase 1
# Desde un contenedor Docker, "localhost" del host es host.docker.internal.
# ----------------------------------------------------------------------------
SCRAPER_API_BASE_URL="http://localhost:3000"
SCRAPER_API_TOKEN="dev-shared-secret-cambiar"
SCRAPER_POLL_INTERVAL_MS="15000"
SCRAPER_HEADLESS="true"
# Proxy residencial (opcional, Fase 3): http://user:pass@host:port
SCRAPER_PROXY_URL=""

# ----------------------------------------------------------------------------
# Email (notificaciones de liquidacion) — local usa Mailpit (docker compose)
# ----------------------------------------------------------------------------
SMTP_HOST="localhost"
SMTP_PORT="1025"
EMAIL_FROM="ARRIENDA+ <no-reply@arriendamas.local>"

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
APP_BASE_URL="http://localhost:3000"
APP_ENV="development"
