{
  "name": "arrienda-plus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ARRIENDA+ — Plataforma de gestion y recaudo de arriendos con servicios publicos",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "dev:scraper": "bun run --cwd apps/scraper dev",
    "build": "bun run --cwd apps/web build",
    "deploy": "bun run --cwd apps/web deploy",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --cwd packages/shared test",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@supabase/supabase-js": "^2.103.3",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^15.15.0",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14"
}
